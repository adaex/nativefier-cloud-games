#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"

found=0
for app in dist/*/*.app; do
  [ -d "$app" ] || continue
  name=$(basename "$app")
  rm -rf "/Applications/$name"
  cp -R "$app" "/Applications/$name"
  echo "已安装: /Applications/$name"
  found=1
done

if [ "$found" -eq 0 ]; then
  echo "没有找到 .app，请先运行 ./build" >&2
  exit 1
fi
